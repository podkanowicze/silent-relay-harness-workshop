# Lobby capacity. The host manually starts with the joined roster (minimum 2).
WORKSHOP_PARTICIPANTS=12
WORKSHOP_MIN_PARTICIPANTS=2
WORKSHOP_EXERCISES=
WORKSHOP_ROUTING_MODE=circular
WORKSHOP_AGENT_MODE=dcode
WORKSHOP_MODEL=gpt-5.6-luna
WORKSHOP_REASONING_EFFORT=high
WORKSHOP_AGENT_MAX_TURNS=50
WORKSHOP_OPEN_BROWSER=true
WORKSHOP_HOST=0.0.0.0
WORKSHOP_PORT=8000

# Set only in the server environment. Never commit a real value.
DEEPAGENTS_CODE_OPENAI_API_KEY=
WORKSHOP_ADMIN_CODE=

# Full workshop example:
# WORKSHOP_ROUTING_MODE=skip_author
# WORKSHOP_AGENT_MODE=dcode
# WORKSHOP_HOST=0.0.0.0
